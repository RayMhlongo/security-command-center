rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function adminAccess() { return signedIn() && userDoc().role in ['owner', 'management', 'admin']; }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == uid;
    }

    match /{company}_{collection}/{docId} {
      allow read: if adminAccess();
      allow create, update, delete: if adminAccess();
    }

    match /auditLogs/{docId} {
      allow read, create: if adminAccess();
    }
  }
}
